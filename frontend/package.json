{
  "name": "door-window-watcher-frontend",
  "version": "1.0.0",
  "description": "Frontend for the Door Window Watcher integration (card + panel)",
  "scripts": {
    "build": "npm run build:card && npm run build:panel",
    "build:card": "vite build",
    "build:panel": "vite build -c vite.config.panel.ts",
    "watch": "vite build --watch --mode development"
  },
  "dependencies": {
    "lit": "3.3.2",
    "dayjs": "1.11.19",
    "home-assistant-js-websocket": "9.6.0",
    "@mdi/js": "^7.4.47"
  },
  "devDependencies": {
    "vite": "^7.3.1",
    "typescript": "^5.7.2",
    "ts-lit-plugin": "2.0.2"
  }
}
